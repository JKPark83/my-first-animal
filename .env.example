# 🦙 나의 첫 알파카 농장 — 로블록스 Open Cloud 배포용 비밀값
#
# 사용법:
#   1) 이 파일을 .env 로 복사:  cp .env.example .env
#   2) 아래 3개 값을 채우기
#   3) ./deploy.sh 실행
#
# ⚠️ .env 는 비밀키가 들어있으니 절대 git/채팅/공유에 올리지 마세요. (.gitignore 처리됨)

# create.roblox.com/dashboard/credentials 에서 발급한 Open Cloud API 키
# 권한(Scope): "universe-places:write", 위 게임(Universe) 선택 필수
ROBLOX_API_KEY=

# 게임(Experience)의 Universe ID
# Creator Hub > 게임 > ⋯ > Copy Universe ID
ROBLOX_UNIVERSE_ID=

# 게임의 Place ID (게임 URL 의 숫자: roblox.com/games/<이 숫자>/...)
ROBLOX_PLACE_ID=
